# Supabase credentials — required at build time (Vite inlines VITE_* vars into the bundle).
# Copy to .env for local development. Do NOT commit real values.
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-public-key

# --- Supabase Edge Function secrets (server-side only) ---
# These are NOT read by the frontend and must NOT be prefixed with VITE_.
# Set them as Edge Function secrets rather than committing them:
#   supabase secrets set RESEND_API_KEY=... INVITE_FROM_EMAIL="Inferno <celeste@infernotaskboard.com>"
#
# RESEND_API_KEY    (required) Resend API key used by the send-board-invite function.
# INVITE_FROM_EMAIL (optional) Verified sender. Defaults to "Inferno <celeste@infernotaskboard.com>".
RESEND_API_KEY=re_your_resend_api_key
INVITE_FROM_EMAIL=Inferno <celeste@infernotaskboard.com>
