# Supabase credentials — required at build time (Vite inlines VITE_* vars into the bundle).
# Copy to .env for local development. Do NOT commit real values.
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-public-key

# Canonical site URL used for auth email redirects and invite accept links.
# Defaults to https://infernotaskboard.com/ when unset. Override for local dev,
# e.g. VITE_SITE_URL=http://localhost:5173
VITE_SITE_URL=https://infernotaskboard.com/

# Optional browser error monitoring. When set, uncaught errors and unhandled
# promise rejections are POSTed as JSON to this endpoint (via sendBeacon). Leave
# unset to disable entirely — no SDK, no cost, no requests. The endpoint can be a
# Supabase Edge Function or any collector you control that accepts a JSON POST.
# VITE_ERROR_MONITOR_URL=https://your-collector.example.com/ingest

# --- Supabase Edge Function secrets (server-side only) ---
# These are NOT read by the frontend and must NOT be prefixed with VITE_.
# Set them as Edge Function secrets rather than committing them:
#   supabase secrets set RESEND_API_KEY=... INVITE_FROM_EMAIL="Inferno <celeste@infernotaskboard.com>"
#
# RESEND_API_KEY    (required) Resend API key used by the send-board-invite function.
# INVITE_FROM_EMAIL (optional) Verified sender. Defaults to "Inferno <celeste@infernotaskboard.com>".
RESEND_API_KEY=re_your_resend_api_key
INVITE_FROM_EMAIL=Inferno <celeste@infernotaskboard.com>
